# ============================================================
# code-to-cloud-demo · .env.sample
# Copy to .env and populate. Never commit .env to git.
# ============================================================

# --- Required for azd (Demo 1 & 2) ---
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_LOCATION=canadacentral
AZURE_ENV_NAME=ctc-demo
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# --- Auto-populated by azd after provision (do not set manually) ---
# AZURE_RESOURCE_GROUP=rg-ctc-demo
# AZURE_CONTAINER_REGISTRY_ENDPOINT=
# AZURE_CONTAINER_REGISTRY_NAME=
# AZURE_CONTAINER_APPS_ENVIRONMENT_ID=
# AZURE_KEY_VAULT_NAME=
# APPLICATIONINSIGHTS_CONNECTION_STRING=
# SERVICE_API_URI=

# --- Required for Demo 3: Backstage Developer Portal ---

# PostgreSQL password (min 8 chars, must include upper, lower, digit, symbol)
BACKSTAGE_POSTGRES_PASSWORD=

# Microsoft Entra ID app registration (for Backstage SSO)
# Create at: https://portal.azure.com → App registrations → New registration
# Redirect URI: https://<backstage-fqdn>/api/auth/microsoft/handler/frame
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=

# GitHub PAT for the scaffolder (needs repo + workflow scopes)
GITHUB_TOKEN=

# Optional: AKS integration (leave blank to disable Kubernetes plugin)
K8S_URL=
K8S_SA_TOKEN=

# Local Backstage dev server URLs (auto-set by setup-demo3.sh for prod)
BACKSTAGE_BASE_URL=http://localhost:3000
BACKSTAGE_BACKEND_BASE_URL=http://localhost:7007

# --- Optional: GitHub Actions OIDC (set as repo secrets, not in .env) ---
# AZURE_CLIENT_ID=
# AZD_INITIAL_ENVIRONMENT_CONFIG=
